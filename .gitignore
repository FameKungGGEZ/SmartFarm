photos/*.jpg
photos/*.jpeg
photos/*.png

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Pytest
.pytest_cache/
htmlcov/
.coverage

# Docker
*.dockerignore
